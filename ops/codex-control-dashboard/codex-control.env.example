# Copy to a private VM-only path such as ~/.hermes/codex-control.env.
# Never commit the filled file.

HOST=127.0.0.1
PORT=17640
HERMES_BIN=/path/to/hermes
HERMES_EXEC_MODE=native

DASHBOARD_BOARDS=codex-control,default,kk-job,hermes-hybrid
DASHBOARD_STATE_MODE=sqlite
DASHBOARD_FAST_STATE=1
DASHBOARD_INCLUDE_ARCHIVED=0

SUPERVISOR_AUTO_START=1
SUPERVISOR_BOARD=codex-control
SUPERVISOR_CONCURRENCY=4

CONTROL_SHARED_SECRET=<GENERATE_WITH_PASSWORD_MANAGER>
DISCORD_SHARED_SECRET=<GENERATE_WITH_PASSWORD_MANAGER>
DISCORD_BOT_TOKEN=<YOUR_DISCORD_BOT_TOKEN>
DISCORD_ALLOWED_USER_IDS=<YOUR_DISCORD_USER_ID_CSV>
DISCORD_CHANNEL_IDS=<YOUR_DISCORD_CHANNEL_ID_CSV>
DISCORD_GATEWAY_QUEUE_CHANNEL_IDS=<YOUR_QUEUE_CHANNEL_ID_CSV>
DISCORD_STATE_ENDPOINT=http://127.0.0.1:17640/api/summary?board=codex-control

# Enable only when serving Discord Interactions at /api/discord/interactions.
DISCORD_INTERACTIONS_ENABLED=0
DISCORD_PUBLIC_KEY=
