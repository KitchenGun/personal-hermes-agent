# Copy to a private .env outside the public repository and fill locally.
HERMES_ENV=public-example
HERMES_TIMEZONE=<YOUR_TIMEZONE>
HERMES_DEFAULT_MODEL=${HERMES_REASONING_MODEL}
HERMES_FAST_MODEL=<YOUR_FAST_MODEL_NAME>
HERMES_REASONING_MODEL=<YOUR_REASONING_MODEL_NAME>
HERMES_RESEARCH_MODEL=<YOUR_RESEARCH_MODEL_NAME>
HERMES_CODING_MODEL=<YOUR_CODING_MODEL_NAME>
DISCORD_BOT_TOKEN=<YOUR_DISCORD_BOT_TOKEN>
DISCORD_DEFAULT_CHANNEL_ID=<YOUR_DISCORD_CHANNEL_ID>
GITHUB_TOKEN=<YOUR_GITHUB_TOKEN>
WEATHER_PROVIDER_KEY=<YOUR_WEATHER_PROVIDER_KEY>

# Weekly GitHub SNS publisher placeholders. Real OAuth values stay VM-local only.
SNS_AUTOMATION_STATE_DIR=<YOUR_VM_LOCAL_SNS_STATE_DIR>
SNS_GITHUB_REPOS=<YOUR_REPOSITORY_SLUG>
SNS_BROWSER_HANDOFF_ENABLED=1
SNS_LINKEDIN_PUBLISH_ENABLED=0
SNS_LINKEDIN_AUTHOR_URN=<YOUR_LINKEDIN_AUTHOR_URN>
SNS_LINKEDIN_VERSION=<YOUR_LINKEDIN_API_VERSION_YYYYMM>
SNS_X_PUBLISH_ENABLED=0
SNS_X_USER_ID=<YOUR_X_USER_ID>
SNS_META_GRAPH_VERSION=<YOUR_META_GRAPH_VERSION>
SNS_META_USER_ACCESS_TOKEN=<YOUR_META_USER_ACCESS_TOKEN>
SNS_FACEBOOK_PUBLISH_ENABLED=0
SNS_FACEBOOK_PAGE_ID=<YOUR_FACEBOOK_PAGE_ID>
SNS_FACEBOOK_PAGE_ACCESS_TOKEN=<YOUR_FACEBOOK_PAGE_ACCESS_TOKEN>
SNS_INSTAGRAM_PUBLISH_ENABLED=0
SNS_INSTAGRAM_USER_ID=<YOUR_INSTAGRAM_USER_ID>
SNS_INSTAGRAM_ACCESS_TOKEN=<YOUR_INSTAGRAM_ACCESS_TOKEN>
SNS_INSTAGRAM_MEDIA_URL=<YOUR_PUBLIC_IMAGE_OR_VIDEO_URL>

# Workout automation safeguards, non-secret placeholders
WORKOUT_SPREADSHEET_URL=<YOUR_WORKOUT_SPREADSHEET_URL>
WORKOUT_SHEET_RANGE=<YOUR_WORKOUT_SHEET_RANGE>
WORKOUT_DISCORD_CHANNEL_ID=<YOUR_WORKOUT_DISCORD_CHANNEL_ID>
WORKOUT_CALENDAR_ID=<YOUR_WORKOUT_CALENDAR_ID>
WORKOUT_TIMEZONE=${HERMES_TIMEZONE}
